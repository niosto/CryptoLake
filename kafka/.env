# CryptoLake — Módulo 1 environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit credentials.

# MongoDB credentials
MONGO_USER=cryptolake
MONGO_PASSWORD=cryptolake123

# Kafka (internal Docker network address — change only if needed)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=crypto-prices

# Producer poll interval in seconds (default: 30)
POLL_INTERVAL_SECONDS=30
IP_ADDRESS=98.91.118.194
